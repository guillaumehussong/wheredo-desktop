# Copy to .env (next to the executable, or in the Wheredo data folder:
# Windows: %APPDATA%\Wheredo\.env — Linux: ~/.config/Wheredo/.env)
# Same keys as the macOS app.

# xAI models
VISION_MODEL=grok-4.3
TTS_VOICE=eve
API_BASE=https://api.x.ai/v1

# Vision speed (lower detail / scale = faster analysis)
VISION_IMAGE_DETAIL=low
VISION_JPEG_QUALITY=0.6
CAPTURE_SCALE=1
VISION_MAX_TOKENS=300
VISION_TEMPERATURE=0.2

# Speech languages (BCP-47)
STT_LANGUAGE=en
TTS_LANGUAGE=en

# Latency tuning
STT_SILENCE=0.9        # seconds of silence to end recording (lower = snappier)
TTS_ENGINE=xai         # "xai" = Grok voice (natural, ~1-3s network)
SPEAK_FILLER=true      # say "let me take a look…" while the model thinks

# Red guide cursor overlay (does not move your mouse)
SHOW_GUIDE_CURSOR=true
GUIDE_CURSOR_DURATION=15

# Global hotkey (desktop only; macOS app uses Cmd+$)
HOTKEY=Ctrl+Shift+B
