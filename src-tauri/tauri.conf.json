{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wheredo",
  "version": "0.1.0",
  "identifier": "app.wheredo.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Wheredo",
        "width": 460,
        "height": 400,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage"],
    "category": "Utility",
    "shortDescription": "Voice assistant that sees your screen",
    "longDescription": "Press a hotkey, ask a question out loud, and Grok looks at your screen, answers with voice, and shows a red guide cursor where to click.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": ["English"]
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libxdo3"]
      }
    }
  }
}
